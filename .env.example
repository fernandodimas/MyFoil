# MyFoil Environment Variables
# Copy this file to .env and adjust as needed.

# Database
DATABASE_URL=sqlite:///data/myfoil.db

# Redis (optional - required for Celery/WebSocket clustering)
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_ENABLED=false
CELERY_REQUIRED=false
FLUSH_REDIS_ON_STARTUP=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=

# SocketIO CORS
SOCKETIO_CORS_ORIGINS=http://localhost:8465

# File Watcher
WATCHDOG_INTERVAL=10.0

# RAW API Keys
RAWG_API_KEY=

# Admin user (created on first startup if set)
USER_ADMIN_NAME=
USER_ADMIN_PASSWORD=

# Guest user (created on first startup if set)
USER_GUEST_NAME=
USER_GUEST_PASSWORD=
